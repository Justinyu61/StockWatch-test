# 資料庫
DATABASE_URL=postgresql://stockwatch:stockwatch@localhost:5432/stockwatch

# LINE Bot（進退場提醒用）
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_USER_ID=your_line_user_id

# Fugle API（台股即時，申請後填入）
FUGLE_API_KEY=

# Finnhub API（美股即時，申請後填入）
FINNHUB_API_KEY=

# 資料更新頻率（秒）
POLL_INTERVAL=60
