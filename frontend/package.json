{
  "name": "stockwatch",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "electron:dev": "ELECTRON_DEV=true electron .",
    "electron:preview": "vite build && electron .",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "chart.js": "^4.5.1",
    "chartjs-chart-financial": "^0.2.1",
    "lightweight-charts": "^5.1.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vue/tsconfig": "^0.9.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "npm-run-all2": "^8.0.4",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vue-tsc": "^3.2.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "build": {
    "appId": "com.stockwatch.app",
    "productName": "StockWatch",
    "copyright": "Copyright © 2025",
    "mac": {
      "category": "public.app-category.finance",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "identity": null,
      "signIgnore": [
        "backend/venv"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/tests/**",
          "!venv/lib/python*/site-packages/pip/**",
          "!venv/lib/python*/site-packages/setuptools/**"
        ]
      }
    ],
    "directories": {
      "output": "../release",
      "buildResources": "build"
    },
    "asar": true
  }
}
